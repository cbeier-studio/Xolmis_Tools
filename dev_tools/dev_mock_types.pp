    EnumValues: TStringList;
    Multiple: Boolean;
    Weights: TStringList;
    RangeMin: string;
    RangeMax: string;
    Mask: string;
    Source: string;
    SourceTable: string;
    SourceField: string;
    FilterBy: TStringList;
    Func: string;
    Args: TColumnArgs;
    DependsOn: TStringList;

    constructor Create;
    destructor Destroy; override;
  end;

  TColumnList = specialize TFPGObjectList<TColumn>;

  { TTableSchema }

  TTableSchema = class
  public
    TableName: string;
    Relations: TRelations;
    Polymorphic: TPolymorphic;
    Hierarchy: THierarchy;
    ExternalSources: TExternalSourceList;
    Columns: TColumnList;

    constructor Create;
    destructor Destroy; override;

    procedure LoadFromJSON(const FileName: string);
    procedure Validate;
  end;

  TStringListMap = specialize TFPGMap<string, TStringList>;

  { TTableDependencyResolver }

  TTableDependencyResolver = class
  private
    FGraph: TStringListMap;
    FInDegree: specialize TFPGMap<string, Integer>;
    procedure AddEdge(const FromTable, ToTable: string);
  public
    constructor Create;
    destructor Destroy; override;

    function Resolve(Config: TGeneratorConfig): TStringList;
  end;

  { TColumnDependencyResolver }

  TColumnDependencyResolver = class
  private
    FGraph: TStringListMap;
    FInDegree: specialize TFPGMap<string, Integer>;
    procedure AddEdge(const FromCol, ToCol: string);
  public
    constructor Create;
    destructor Destroy; override;

    function Resolve(Schema: TTableSchema): TStringList;
  end;

  { TMockDataGenerator }

  TMockDataGenerator = class
  private
    FConfig: TGeneratorConfig;
    FSchemas: specialize TFPGMap<string, TTableSchema>;
    FValueGen: TValueGenerator;

    procedure LoadSchemas;
    function ResolveTableOrder: TStringList;
    function ResolveColumnOrder(ASchema: TTableSchema): TStringList;

    function GenerateColumnValue(Col: TColumn; Row: TStringList; Schema: TTableSchema): string;
    procedure GenerateTable(const Schema: TTableSchema; const OutputFile: string);
  public
    constructor Create;
    destructor Destroy; override;

    procedure LoadConfig(const FileName: string);
    procedure GenerateAll;
  end;

  procedure Require(const Condition: Boolean; const Msg: string);
  procedure RequireNonEmpty(const S, FieldName: string);
  procedure RequireInSet(const S, FieldName: string; const Allowed: array of string);
  procedure RequireRangeInt(Value, Min, Max: Integer; const FieldName: string);


implementation

procedure Require(const Condition: Boolean; const Msg: string);
begin
  if not Condition then
    raise Exception.Create('Validation error: ' + Msg);
end;

procedure RequireNonEmpty(const S, FieldName: string);
begin
  if Trim(S) = '' then
    raise Exception.Create('Validation error: field "' + FieldName + '" cannot be empty.');
end;

procedure RequireInSet(const S, FieldName: string; const Allowed: array of string);
var
  i: Integer;
begin
  for i := 0 to High(Allowed) do
    if SameText(S, Allowed[i]) then Exit;

  raise Exception.CreateFmt(
    'Validation error: field "%s" has invalid value "%s". Allowed: %s',
    [FieldName, S, String.Join(', ', Allowed)]
  );
end;

procedure RequireRangeInt(Value, Min, Max: Integer; const FieldName: string);
begin
  if (Value < Min) or (Value > Max) then
    raise Exception.CreateFmt(
      'Validation error: field "%s" must be between %d and %d (got %d)',
      [FieldName, Min, Max, Value]
    );
end;

