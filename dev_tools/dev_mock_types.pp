procedure TTableSchema.LoadFromJSON(const FileName: string);
var
  JSON: TJSONData;
  Obj, Sub: TJSONObject;
  Arr: TJSONArray;
  i, j: Integer;
  Col: TColumn;
  Ext: TExternalSource;
  Lev: THierarchyLevel;
begin
  JSON := GetJSON(ReadFileToString(FileName));
  Obj := TJSONObject(JSON);

  { table }
  TableName := Obj.Get('table', '');

  { relations }
  if Obj.Find('relations') <> nil then
  begin
    Sub := Obj.Objects['relations'];
    Relations.Parent := Sub.Get('parent', '');
    Relations.ParentKey := Sub.Get('parentKey', '');
    Relations.ForeignKey := Sub.Get('foreignKey', '');
    Relations.OptionalParent := Sub.Get('optionalParent', False);
    Relations.MinChildren := Sub.Get('minChildren', 0);
    Relations.MaxChildren := Sub.Get('maxChildren', 10);
  end;

  { polymorphic }
  if Obj.Find('polymorphic') <> nil then
  begin
    Sub := Obj.Objects['polymorphic'];
    Polymorphic.TableField := Sub.Get('tableField', '');
    Polymorphic.IdField := Sub.Get('idField', '');

    Polymorphic.AllowedTables.Clear;
    Arr := Sub.Arrays['allowedTables'];
    for i := 0 to Arr.Count - 1 do
      Polymorphic.AllowedTables.Add(Arr.Strings[i]);
  end;

  { hierarchy }
  if Obj.Find('hierarchy') <> nil then
  begin
    Sub := Obj.Objects['hierarchy'];
    Hierarchy.RankField := Sub.Get('rankField', '');
    Hierarchy.ParentField := Sub.Get('parentField', '');

    Hierarchy.Levels.Clear;
    Arr := Sub.Arrays['levels'];
    for i := 0 to Arr.Count - 1 do
    begin
      Lev := THierarchyLevel.Create;
      Lev.Rank := Arr.Objects[i].Get('rank', '');
      Lev.Min := Arr.Objects[i].Get('min', 0);
      Lev.Max := Arr.Objects[i].Get('max', 0);
      Lev.Source := Arr.Objects[i].Get('source', '');
      Hierarchy.Levels.Add(Lev);
    end;
  end;

  { externalSource }
  if Obj.Find('externalSource') <> nil then
  begin
    ExternalSources.Clear;
    Sub := Obj.Objects['externalSource'];

    for i := 0 to Sub.Count - 1 do
    begin
      Ext := TExternalSource.Create;
      Ext.Name := Sub.Names[i];

      with Sub.Objects[Ext.Name] do
      begin
        Ext.FileName := Get('file', '');
        Ext.CountryField := Get('countryField', '');
        Ext.StateField := Get('stateField', '');
        Ext.CityField := Get('cityField', '');
        Ext.LocalitiesSource := Get('localitiesSource', '');

        if Find('allowedCountries') <> nil then
        begin
          Arr := Arrays['allowedCountries'];
          for j := 0 to Arr.Count - 1 do
            Ext.AllowedCountries.Add(Arr.Strings[j]);
        end;
      end;

      ExternalSources.Add(Ext);
    end;
  end;

  { columns }
  Columns.Clear;
  Arr := Obj.Arrays['columns'];

  for i := 0 to Arr.Count - 1 do
  begin
    Sub := Arr.Objects[i];
    Col := TColumn.Create;

    Col.Name := Sub.Get('name', '');
    Col.DataType := Sub.Get('type', '');
    Col.AutoIncrement := Sub.Get('autoIncrement', False);
    Col.Unique := Sub.Get('unique', False);
    Col.GenerationMode := Sub.Get('generationMode', '');
    Col.StartAt := Sub.Get('startAt', 1);
    Col.IncrementBy := Sub.Get('incrementBy', 1);
    Col.Nullable := Sub.Get('nullable', False);
    Col.DefaultValue := Sub.Get('default', '');
    Col.FixedValue := Sub.Get('fixed', '');
    Col.Ignore := Sub.Get('ignore', False);
    Col.Mask := Sub.Get('mask', '');
    Col.Source := Sub.Get('source', '');
    Col.SourceTable := Sub.Get('sourceTable', '');
    Col.SourceField := Sub.Get('sourceField', '');

    { enum }
    if Sub.Find('enum') <> nil then
    begin
      Arr := Sub.Arrays['enum'];
      for j := 0 to Arr.Count - 1 do
        Col.EnumValues.Add(Arr.Items[j].AsString);
    end;

    { weights }
    if Sub.Find('weights') <> nil then
    begin
      Arr := Sub.Arrays['weights'];
      for j := 0 to Arr.Count - 1 do
        Col.Weights.Add(FloatToStr(Arr.Items[j].AsFloat));
    end;

    { range }
    if Sub.Find('range') <> nil then
    begin
      Col.RangeMin := Sub.Arrays['range'].Items[0].AsString;
      Col.RangeMax := Sub.Arrays['range'].Items[1].AsString;
    end;

    { filterBy }
    if Sub.Find('filterBy') <> nil then
    begin
      for j := 0 to Sub.Objects['filterBy'].Count - 1 do
        Col.FilterBy.Add(Sub.Objects['filterBy'].Names[j] + '=' +
                         Sub.Objects['filterBy'].Items[j].AsString);
    end;

    { function + args }
    Col.Func := Sub.Get('function', '');

    if Sub.Find('args') <> nil then
    begin
      for j := 0 to Sub.Objects['args'].Count - 1 do
        Col.Args.Raw.Add(Sub.Objects['args'].Names[j] + '=' +
                         Sub.Objects['args'].Items[j].AsString);
    end;

    { dependsOn }
    if Sub.Find('dependsOn') <> nil then
    begin
      Arr := Sub.Arrays['dependsOn'];
      for j := 0 to Arr.Count - 1 do
        Col.DependsOn.Add(Arr.Strings[j]);
    end;

    Columns.Add(Col);
  end;

  JSON.Free;
end;

procedure TTableSchema.Validate;
var
  i: Integer;
  Col: TColumn;
  Ext: TExternalSource;
begin
  RequireNonEmpty(TableName, 'table');

  { Validate relations }
  if Relations.Parent <> '' then
  begin
    RequireNonEmpty(Relations.ParentKey, 'relations.parentKey');
    RequireNonEmpty(Relations.ForeignKey, 'relations.foreignKey');
  end;

  { Validate polymorphic }
  if Polymorphic.TableField <> '' then
  begin
    RequireNonEmpty(Polymorphic.IdField, 'polymorphic.idField');
    Require(Polymorphic.AllowedTables.Count > 0,
      'polymorphic.allowedTables cannot be empty');
  end;

  { Validate hierarchy }
  if Hierarchy.RankField <> '' then
  begin
    RequireNonEmpty(Hierarchy.ParentField, 'hierarchy.parentField');
    Require(Hierarchy.Levels.Count > 0, 'hierarchy.levels cannot be empty');
  end;

  { Validate external sources }
  for i := 0 to ExternalSources.Count - 1 do
  begin
    Ext := ExternalSources[i];
    RequireNonEmpty(Ext.FileName, 'externalSource[' + Ext.Name + '].file');
  end;

  { Validate columns }
  Require(Columns.Count > 0, 'columns cannot be empty');

  for i := 0 to Columns.Count - 1 do
  begin
    Col := Columns[i];

    RequireNonEmpty(Col.Name, 'columns[' + IntToStr(i) + '].name');
    RequireInSet(Col.DataType, 'columns[' + IntToStr(i) + '].type',
      ['integer', 'float', 'string', 'boolean', 'date', 'datetime']);

    if Col.GenerationMode <> '' then
      RequireInSet(Col.GenerationMode, 'generationMode',
        ['random', 'sequential', 'incremental', 'conditional', 'template', 'list']);

    if Col.EnumValues.Count > 0 then
      Require(Col.Weights.Count = 0
        or (Col.Weights.Count = Col.EnumValues.Count),
        'weights must match enum length');

    if (Col.SourceTable <> '') xor (Col.SourceField <> '') then
      raise Exception.Create('sourceTable and sourceField must be used together');

    if Col.RangeMin <> '' then
      Require(Col.RangeMax <> '', 'range must have two values');
  end;
end;

{ TTableDependencyResolver }

constructor TTableDependencyResolver.Create;
begin
  FGraph := TStringListMap.Create;
  FInDegree := specialize TFPGMap<string, Integer>.Create;
end;

procedure TTableDependencyResolver.AddEdge(const FromTable, ToTable: string);
var
  L: TStringList;
begin
  if not FGraph.TryGetData(FromTable, L) then
  begin
    L := TStringList.Create;
    FGraph.Add(FromTable, L);
  end;
  L.Add(ToTable);
end;

destructor TTableDependencyResolver.Destroy;
var
  i: Integer;
begin
  for i := 0 to FGraph.Count - 1 do
    FGraph.Data[i].Free;
  FGraph.Free;
  FInDegree.Free;
  inherited Destroy;
end;

function TTableDependencyResolver.Resolve(Config: TGeneratorConfig): TStringList;
var
  i, j: Integer;
  S: TSchemaRef;
  Dep: string;
  Queue: TStringList;
  Node, Neighbor: string;
  L: TStringList;
begin
  Result := TStringList.Create;

  { Inicializa in-degree }
  for i := 0 to Config.Schemas.Count - 1 do
  begin
    S := Config.Schemas[i];
    FInDegree.Add(S.Name, 0);
  end;

  { Constrói o grafo }
  for i := 0 to Config.Schemas.Count - 1 do
  begin
    S := Config.Schemas[i];
    for j := 0 to S.Dependencies.Count - 1 do
    begin
      Dep := S.Dependencies[j];

      if FInDegree.IndexOf(Dep) = -1 then
        raise Exception.Create('Unknown dependency: ' + Dep);

      AddEdge(Dep, S.Name);
      FInDegree[S.Name] := FInDegree[S.Name] + 1;
    end;
  end;

  { Kahn's algorithm }
  Queue := TStringList.Create;
  try
    for i := 0 to FInDegree.Count - 1 do
      if FInDegree.Data[i] = 0 then
        Queue.Add(FInDegree.Keys[i]);

    while Queue.Count > 0 do
    begin
      Node := Queue[0];
      Queue.Delete(0);
      Result.Add(Node);

      if FGraph.TryGetData(Node, L) then
      begin
        for Neighbor in L do
        begin
          FInDegree[Neighbor] := FInDegree[Neighbor] - 1;
          if FInDegree[Neighbor] = 0 then
            Queue.Add(Neighbor);
        end;
      end;
    end;

    if Result.Count <> FInDegree.Count then
      raise Exception.Create('Cycle detected in table dependencies.');
  finally
    Queue.Free;
  end;
end;

