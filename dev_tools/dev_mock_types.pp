{ TGeneratorConfig }

constructor TGeneratorConfig.Create;
begin
  GenerationOrder := TStringList.Create;
  GlobalOptions := TGlobalOptions.Create;
  Schemas := TSchemaRefList.Create(True);
  Repositories := TRepositoryRefList.Create(True);
end;

destructor TGeneratorConfig.Destroy;
begin
  GenerationOrder.Free;
  GlobalOptions.Free;
  Schemas.Free;
  Repositories.Free;
  inherited Destroy;
end;

function TGeneratorConfig.GetSchemaByName(const AName: String): TSchemaRef;
begin
  Result := nil;

  for i := 0 to Schemas.Count - 1 do
  begin
    if SameText(Schemas.Items[i].Name, AName) then
    begin
      Result := Schemas.Items[i];
      Break;
    end;
  end;
end;

procedure TGeneratorConfig.LoadFromJSON(const FileName: string);
var
  JSON: TJSONData;
  Obj: TJSONObject;
  Arr: TJSONArray;
  Item: TJSONData;
  SRef: TSchemaRef;
  RRef: TRepositoryRef;
  i, j: Integer;
begin
  JSON := GetJSON(ReadFileToString(FileName));
  Obj := TJSONObject(JSON);

  { version }
  Version := Obj.Get('version', 1);

  { generationOrder }
  GenerationOrder.Clear;
  Arr := Obj.Arrays['generationOrder'];
  for i := 0 to Arr.Count - 1 do
    GenerationOrder.Add(Arr.Strings[i]);

  { globalOptions }
  with GlobalOptions do
  begin
    TemporalCoherence := Obj.Objects['globalOptions'].Get('temporalCoherence', True);
    SpatialCoherence := Obj.Objects['globalOptions'].Get('spatialCoherence', True);
    MaxRecordsPerTable := Obj.Objects['globalOptions'].Get('maxRecordsPerTable', 10000);
    AutoGenerateDependencies := Obj.Objects['globalOptions'].Get('autoGenerateDependencies', True);
    ForceRegenerateDependencies := Obj.Objects['globalOptions'].Get('forceRegenerateDependencies', False);
    AutoGenerateDescendants := Obj.Objects['globalOptions'].Get('autoGenerateDescendants', True);
    OutputDir := Obj.Objects['globalOptions'].Get('outputDir', './output');
  end;

  { schemas }
  Schemas.Clear;
  Arr := Obj.Arrays['schemas'];
  for i := 0 to Arr.Count - 1 do
  begin
    Item := Arr.Items[i];
    SRef := TSchemaRef.Create;

    SRef.Name := Item.FindPath('name').AsString;
    SRef.FileName := Item.FindPath('file').AsString;
    SRef.DefaultCount := Item.FindPath('defaultCount').AsInteger;
    SRef.MaxCount := Item.FindPath('maxCount').AsInteger;

    { dependencies }
    if Item.FindPath('dependencies') <> nil then
      for j := 0 to Item.FindPath('dependencies').Count - 1 do
        SRef.Dependencies.Add(Item.FindPath('dependencies').Items[j].AsString);

    { outputFiles }
    if Item.FindPath('outputFiles') <> nil then
      for j := 0 to Item.FindPath('outputFiles').Count - 1 do
        SRef.OutputFiles.Add(Item.FindPath('outputFiles').Items[j].AsString);

    Schemas.Add(SRef);
  end;

  { repositories }
  Repositories.Clear;
  Arr := Obj.Arrays['repositories'];
  for i := 0 to Arr.Count - 1 do
  begin
    Item := Arr.Items[i];
    RRef := TRepositoryRef.Create;

    RRef.Name := Item.FindPath('name').AsString;
    RRef.FileName := Item.FindPath('file').AsString;
    RRef.RepoType := Item.FindPath('type').AsString;

    if Item.FindPath('fields') <> nil then
      for j := 0 to Item.FindPath('fields').Count - 1 do
        RRef.Fields.Add(Item.FindPath('fields').Items[j].AsString);

    Repositories.Add(RRef);
  end;

  JSON.Free;
end;

procedure TGeneratorConfig.Validate;
var
  i: Integer;
  S: TSchemaRef;
  R: TRepositoryRef;
begin
  Require(Version >= 1, 'version must be >= 1');
  Require(GenerationOrder.Count > 0, 'generationOrder cannot be empty');

  { Validate schemas }
  for i := 0 to Schemas.Count - 1 do
  begin
    S := Schemas[i];

    RequireNonEmpty(S.Name, 'schemas[' + IntToStr(i) + '].name');
    RequireNonEmpty(S.FileName, 'schemas[' + IntToStr(i) + '].file');
    RequireRangeInt(S.DefaultCount, 0, S.MaxCount, 'defaultCount');
    RequireRangeInt(S.MaxCount, 0, 10000000, 'maxCount');
  end;

  { Validate repositories }
  for i := 0 to Repositories.Count - 1 do
  begin
    R := Repositories[i];

    RequireNonEmpty(R.Name, 'repositories[' + IntToStr(i) + '].name');
    RequireNonEmpty(R.FileName, 'repositories[' + IntToStr(i) + '].file');
    RequireInSet(R.RepoType, 'repositories[' + IntToStr(i) + '].type',
      ['array', 'objects']);
  end;

  { Validate generationOrder references }
  for i := 0 to GenerationOrder.Count - 1 do
    Require(
      Schemas.IndexOfName(GenerationOrder[i]) <> -1,
      'generationOrder references unknown schema "' + GenerationOrder[i] + '"'
    );
end;

